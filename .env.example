# MC-AI Environment Variables
# Copy to .env and fill in your values

# LLM Provider API Keys (at least one required for real agent execution)
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional: Postgres persistence (only for @mcai/orchestrator-postgres)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/mcai

# Optional: MCP Gateway for external tool execution
# MCP_GATEWAY_URL=http://localhost:3001

# Optional: OpenTelemetry distributed tracing
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

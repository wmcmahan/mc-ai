{
  "name": "@cycgraph/orchestrator",
  "version": "0.1.0-beta.7",
  "description": "Self-improving agent workflows: every run distills lessons into memory, and future runs retrieve them automatically. Cyclic graph engine with durable execution, per-node budgets, taint tracking, and human-in-the-loop gates.",
  "keywords": [
    "agents",
    "compound-learning",
    "self-improving",
    "agent-memory",
    "reflection",
    "orchestrator",
    "workflow",
    "graph-runner",
    "multi-agent",
    "llm",
    "mcp",
    "durable-execution",
    "event-sourcing",
    "human-in-the-loop"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wmcmahan/cycgraph.git",
    "directory": "packages/orchestrator"
  },
  "homepage": "https://github.com/wmcmahan/cycgraph/tree/main/packages/orchestrator#readme",
  "bugs": {
    "url": "https://github.com/wmcmahan/cycgraph/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "default": "./dist/internal.js"
    }
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "vitest run",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.76",
    "@ai-sdk/mcp": "^1.0.41",
    "@ai-sdk/openai": "^3.0.63",
    "@ai-sdk/provider": "^3.0.10",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/exporter-prometheus": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "ai": "^6.0.116",
    "filtrex": "^3.1.0",
    "jsonpath-plus": "^10.4.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@grpc/grpc-js": "^1.14.4",
    "@types/node": "^25.3.5",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
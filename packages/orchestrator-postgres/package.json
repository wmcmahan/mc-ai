{
  "name": "@cycgraph/orchestrator-postgres",
  "version": "1.0.0-beta.3",
  "description": "PostgreSQL persistence adapter for @cycgraph/orchestrator with Drizzle ORM, pgvector, and event sourcing.",
  "keywords": [
    "orchestrator",
    "postgres",
    "persistence",
    "drizzle",
    "pgvector",
    "event-sourcing",
    "workflow"
  ],
  "type": "module",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/wmcmahan/mc-ai.git",
    "directory": "packages/orchestrator-postgres"
  },
  "homepage": "https://github.com/wmcmahan/mc-ai/tree/main/packages/orchestrator-postgres#readme",
  "bugs": {
    "url": "https://github.com/wmcmahan/mc-ai/issues"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema.d.ts",
      "import": "./dist/schema.js",
      "default": "./dist/schema.js"
    }
  },
  "files": [
    "dist",
    "drizzle"
  ],
  "engines": {
    "node": ">=24.0.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run --passWithNoTests",
    "lint": "tsc --noEmit",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "migrate": "tsx scripts/migrate.ts",
    "generate": "drizzle-kit generate",
    "studio": "drizzle-kit studio"
  },
  "peerDependencies": {
    "@cycgraph/orchestrator": "0.1.0-beta.3",
    "@cycgraph/memory": "0.1.0-beta.3"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "pgvector": "^0.2.1",
    "dotenv": "^17.3.1"
  },
  "devDependencies": {
    "@cycgraph/orchestrator": "0.1.0-beta.3",
    "@cycgraph/memory": "0.1.0-beta.3",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18",
    "zod": "^4.3.6"
  }
}
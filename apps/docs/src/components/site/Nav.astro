---
import Logo from './Logo.astro';

const path = Astro.url.pathname;
const links = [
  { label: 'Docs', href: '/docs/' },
  { label: 'Blog', href: '/blog/' },
];
const isActive = (href: string) =>
  href === '/docs/' ? path.startsWith('/docs') : path.startsWith(href);
---

<header class="sticky top-0 z-50 border-b border-canvas-line/70 bg-canvas/80 backdrop-blur-md">
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-6">
    <a href="/" class="group flex items-center gap-2.5" aria-label="cycgraph (beta)">
      <Logo class="h-7 w-7 transition-transform group-hover:scale-105" />
      <span class="font-mono text-[0.95rem] font-bold tracking-[0.16em] text-ink transition-colors group-hover:text-signal">
        CYCGRAPH
      </span>
      <span class="rounded-full border border-cyan/30 bg-cyan/10 px-1.5 py-px font-mono text-[0.58rem] font-bold uppercase tracking-wider text-cyan">
        beta
      </span>
    </a>

    <div class="flex items-center gap-1 sm:gap-1.5">
      {
        links.map((l) => (
          <a
            href={l.href}
            class:list={[
              'rounded-lg px-3.5 py-2 font-mono text-[0.8rem] font-semibold uppercase tracking-wide transition-colors',
              isActive(l.href)
                ? 'bg-signal/10 text-signal'
                : 'text-[#b6bccb] hover:bg-canvas-raised hover:text-ink',
            ]}
          >
            {l.label}
          </a>
        ))
      }

      <a
        href="https://github.com/wmcmahan/cycgraph"
        aria-label="GitHub"
        class="ml-1 flex h-9 w-9 items-center justify-center rounded-lg border border-canvas-line text-[#b6bccb] transition-colors hover:border-signal hover:text-signal"
      >
        <svg viewBox="0 0 24 24" fill="currentColor" class="h-[1.05rem] w-[1.05rem]" aria-hidden="true">
          <path
            fill-rule="evenodd"
            clip-rule="evenodd"
            d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.31.678.921.678 1.856 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.02 10.02 0 0022 12.017C22 6.484 17.522 2 12 2z"
          />
        </svg>
      </a>

      <a
        href="/docs/getting-started/quick-start/"
        class="ml-1 hidden items-center gap-1.5 rounded-lg bg-signal px-4 py-2 font-mono text-[0.8rem] font-bold text-white transition-all hover:-translate-y-px hover:bg-signal-deep sm:inline-flex"
      >
        Get Started
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </nav>
</header>

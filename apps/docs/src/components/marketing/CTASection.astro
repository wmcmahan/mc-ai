---
// Closing call to action.
---

<section class="relative mx-auto max-w-6xl px-6 py-24 lg:py-32">
  <div class="grain relative overflow-hidden rounded-3xl border border-canvas-line bg-canvas-raised/60 px-8 py-16 text-center sm:px-16 sm:py-24">
    <div
      class="pointer-events-none absolute inset-0"
      style="background: radial-gradient(85% 65% at 50% 78%, rgba(91,108,255,0.18), transparent 62%)"
    >
    </div>

    <div class="relative">
      <div class="flex items-center justify-center gap-3 font-mono text-xs uppercase tracking-[0.25em] text-signal">
        <span class="h-px w-8 bg-signal/60"></span>
        Build your first loop
        <span class="h-px w-8 bg-signal/60"></span>
      </div>

      <h2 class="mx-auto mt-6 max-w-2xl font-display text-4xl leading-[1.05] tracking-tight text-ink sm:text-6xl">
        Five minutes from install to a workflow that <span class="bg-gradient-to-r from-signal to-cyan bg-clip-text italic text-transparent">loops.</span>
      </h2>

      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <a
          href="/docs/getting-started/quick-start/"
          class="group inline-flex items-center gap-2 rounded-lg bg-signal px-6 py-3.5 font-mono text-sm font-600 text-white transition-transform hover:-translate-y-0.5"
          style="box-shadow: var(--shadow-glow)"
        >
          Quick Start
          <span class="transition-transform group-hover:translate-x-0.5">→</span>
        </a>
        <a
          href="https://github.com/wmcmahan/cycgraph"
          class="inline-flex items-center gap-2 rounded-lg border border-canvas-line px-6 py-3.5 font-mono text-sm text-ink transition-colors hover:border-signal hover:text-signal"
        >
          Star on GitHub ↗
        </a>
      </div>

      <div class="mt-10 inline-flex items-center gap-3 rounded-lg border border-canvas-line bg-canvas/70 px-4 py-2.5 font-mono text-sm">
        <span class="text-faint">$</span>
        <span class="text-ink">npm install <span class="text-signal">@cycgraph/orchestrator</span></span>
      </div>
    </div>
  </div>
</section>
